generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  phone     String?
  role      String   @default("customer")
  createdAt DateTime @default(now())

  bookings  Booking[]
  reviews   Review[]
}

model Technician {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String
  specialty   String
  bio         String
  hourlyRate  Int
  rating      Float    @default(0)
  reviewCount Int      @default(0)
  responseTime String

  bookings Booking[]
  reviews  Review[]
}

model Booking {
  id           String   @id @default(cuid())
  userId       String
  technicianId String
  serviceType  String
  description  String
  scheduledDate DateTime
  status       String   @default("pending")

  user        User       @relation(fields: [userId], references: [id])
  technician  Technician @relation(fields: [technicianId], references: [id])

  createdAt DateTime @default(now())
}

model Review {
  id           String   @id @default(cuid())
  userId       String
  technicianId String
  rating       Int
  comment      String
  createdAt    DateTime @default(now())

  user        User       @relation(fields: [userId], references: [id])
  technician  Technician @relation(fields: [technicianId], references: [id])
}